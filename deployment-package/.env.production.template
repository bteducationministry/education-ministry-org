# ═══════════════════════════════════════════════════════════
# Environment Configuration Template — Production
# ═══════════════════════════════════════════════════════════
#
# This file documents environment variables needed for the
# deployment. The React SPA uses config.js (not .env files),
# but these values are useful for deployment scripts and
# server configuration.
#
# Copy to .env.production and fill in actual values.
# ═══════════════════════════════════════════════════════════

# --- Domain Configuration ---
APP_DOMAIN=app.educationministry.org
MAIN_SITE_DOMAIN=educationministry.org
API_DOMAIN=api.educationministry.org

# --- VPS Configuration ---
VPS_IP=72.62.80.207
VPS_USER=root
VPS_SSH_PORT=22

# --- Paths ---
DEPLOY_DIR=/var/www/education-ministry-org
BACKUP_DIR=/var/www/backups/education-ministry-org
NGINX_CONF=/etc/nginx/sites-available/education-ministry-org

# --- GitHub ---
GITHUB_REPO=bteducationministry/education-ministry-org
GITHUB_BRANCH=main

# --- SSL ---
SSL_EMAIL=info@educationministry.org

# --- Monitoring ---
# UptimeRobot or similar (free tier)
MONITOR_URL=https://app.educationministry.org
MONITOR_INTERVAL=300  # seconds (5 minutes)

# --- Contact ---
CONTACT_EMAIL=info@educationministry.org
